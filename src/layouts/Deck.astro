---
import '../styles/markdown.css';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    date?: Date;
  };
  headings?: { depth: number; slug: string; text: string }[];
  slug: string;
}

const { frontmatter, headings = [], slug } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const formattedDate = frontmatter.date
  ? new Date(frontmatter.date).toLocaleDateString(undefined, {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : undefined;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {frontmatter.description && <meta name="description" content={frontmatter.description} />}
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <div class="prose">
      <header class="deck-header">
        <a class="back-link" href="/">&larr; All presentations</a>
        <a class="present-link" href={`/markdown/${slug}/present`}>Present &#9654;</a>
        <h1>{frontmatter.title}</h1>
        {formattedDate && <p class="deck-date">{formattedDate}</p>}
      </header>

      {toc.length > 0 && (
        <nav class="deck-toc" aria-label="Table of contents">
          <ul>
            {toc.map((h) => (
              <li class={`toc-depth-${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <article class="deck-content">
        <slot />
      </article>
    </div>
  </body>
</html>

<style>
  .deck-header {
    margin-bottom: 2rem;
  }

  .back-link,
  .present-link {
    font-size: 0.9rem;
    color: var(--color-fg-muted);
  }

  .present-link {
    float: right;
  }

  .deck-header h1 {
    margin-top: 0.5rem;
    margin-bottom: 0.2em;
  }

  .deck-date {
    color: var(--color-fg-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .deck-toc {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    background: var(--color-code-bg);
  }

  .deck-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .deck-toc li {
    margin: 0.25rem 0;
  }

  .deck-toc .toc-depth-3 {
    padding-left: 1.2rem;
    font-size: 0.9em;
  }
</style>
