---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description?: string;
  type: 'md' | 'html' | 'slides';
  href: string;
  date?: Date;
  cover?: ImageMetadata;
}

const { title, description, type, href, date, cover } = Astro.props;

const formattedDate = date
  ? new Date(date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })
  : undefined;
---
<a href={href} class="card">
  {cover && (
    <div class="cover">
      <Image src={cover} alt={title} />
    </div>
  )}
  <div class="card-body">
    <span class={`badge badge-${type}`}>{{ md: 'MD', html: 'HTML', slides: 'SLIDES' }[type]}</span>
    <h2 class="card-title">{title}</h2>
    {description && <p class="card-description">{description}</p>}
    {formattedDate && <p class="card-date">{formattedDate}</p>}
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--color-bg);
    color: var(--color-fg);
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    border-color: var(--color-link);
    text-decoration: none;
  }

  .cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-code-bg);
  }

  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    display: block;
  }

  .card-body {
    padding: 1.1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .badge {
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.2em 0.6em;
    border-radius: 999px;
  }

  .badge-md {
    background: rgba(9, 105, 218, 0.12);
    color: var(--color-link);
  }

  .badge-html {
    background: rgba(230, 126, 34, 0.14);
    color: #c2560c;
  }

  .badge-slides {
    background: rgba(46, 160, 67, 0.14);
    color: #1a7f37;
  }

  @media (prefers-color-scheme: dark) {
    .badge-html {
      color: #f0985a;
    }

    .badge-slides {
      color: #4ac26b;
    }
  }

  .card-title {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .card-description {
    margin: 0;
    color: var(--color-fg-muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .card-date {
    margin: 0.2rem 0 0;
    color: var(--color-fg-muted);
    font-size: 0.8rem;
  }
</style>
